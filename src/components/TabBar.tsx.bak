import { Home, CalendarDays, List, Settings } from 'lucide-react';

interface TabBarProps {
  active: string;
  onNavigate: (page: string) => void;
}

const tabs = [
  { id: 'home', label: '首页', icon: Home },
  { id: 'today', label: '今日', icon: CalendarDays },
  { id: 'records', label: '记录', icon: List },
  { id: 'settings', label: '设置', icon: Settings },
];

export function TabBar({ active, onNavigate }: TabBarProps) {
  return (
    <div className="px-6 pb-3 pt-1.5 shrink-0">
      <nav
        className="flex items-center rounded-[28px] px-2 py-2 safe-area-bottom"
        style={{
          height: '76px',
          background: 'rgba(255,255,255,0.92)',
          border: '1px solid rgba(120,130,180,0.12)',
          backdropFilter: 'blur(20px) saturate(180%)',
          WebkitBackdropFilter: 'blur(20px) saturate(180%)',
          boxShadow: '0 8px 32px rgba(36, 45, 100, 0.1), 0 2px 8px rgba(0,0,0,0.04)',
        }}
      >
        {tabs.map(({ id, label, icon: Icon }) => {
          const isActive = active === id;
          return (
            <button
              key={id}
              onClick={() => onNavigate(id)}
              className={`flex-1 flex flex-col items-center gap-1 py-2.5 rounded-[22px] transition-all duration-200
                ${isActive ? '' : 'active:bg-gray-100/50'}`}
              style={isActive ? {
                background: 'rgba(91, 95, 239, 0.1)',
              } : undefined}
            >
              <Icon
                size={22}
                strokeWidth={isActive ? 2.4 : 1.8}
                className={isActive ? 'text-primary' : 'text-text-muted'}
              />
              <span
                className={`text-[11px] leading-none ${isActive ? 'font-bold text-primary' : 'font-medium text-text-muted'}`}
              >
                {label}
              </span>
            </button>
          );
        })}
      </nav>
    </div>
  );
}
